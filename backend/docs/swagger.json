{
  "swagger": "2.0",
  "info": {
    "description": "REST и GraphQL API каталога организаций",
    "title": "Niklad Catalog API",
    "contact": {},
    "version": "1.0"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "paths": {
    "/api/catalog": {
      "get": {
        "description": "Возвращает категории и организации из PostgreSQL",
        "produces": ["application/json"],
        "tags": ["catalog"],
        "summary": "Каталог организаций",
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/catalog.Data"
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/main.errorResponse"
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "description": "Возвращает ok, если HTTP-сервер запущен",
        "produces": ["text/plain"],
        "tags": ["system"],
        "summary": "Проверка сервера",
        "responses": {
          "200": {
            "description": "ok",
            "schema": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "catalog.Category": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "organizations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/catalog.Organization"
          }
        },
        "slug": {
          "type": "string"
        }
      }
    },
    "catalog.Data": {
      "type": "object",
      "properties": {
        "categories": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/catalog.Category"
          }
        },
        "meta": {
          "$ref": "#/definitions/catalog.Meta"
        }
      }
    },
    "catalog.Meta": {
      "type": "object",
      "properties": {
        "subtitle": {
          "type": "string"
        },
        "totalReviews": {
          "type": "integer"
        }
      }
    },
    "catalog.Organization": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "logoUrl": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "rating": {
          "type": "number"
        },
        "reviewCount": {
          "type": "integer"
        }
      }
    },
    "main.errorResponse": {
      "type": "object",
      "properties": {
        "error": {
          "type": "string",
          "example": "internal server error"
        }
      }
    }
  }
}
